# =============================================================================
# Hetzner Cloud
# =============================================================================

# Names of SSH keys already uploaded to your Hetzner project
ssh_key_names = ["developer"]

# Hetzner datacenter location (default: nbg1)
# Options: nbg1 (Nuremberg), fsn1 (Falkenstein), hel1 (Helsinki), ash (Ashburn)
# location = "nbg1"

# Server type (default: cx23)
# server_type = "cx23"

# Volume size in GB (default: 10)
# volume_size = 10

# =============================================================================
# GitHub
# =============================================================================

# GitHub owner (user or organization name)
github_owner = ""

# Repository name (without owner prefix)
github_repository = ""

# =============================================================================
# Project
# =============================================================================

# Short project identifier used for naming resources
project_name = "myapp"

# Domain name pointing to the server's floating IP
domain = "app.example"

# Docker registry for pulling container images
docker_registry = "ghcr.io"

# =============================================================================
# Email / SMTP
# =============================================================================

# Email address for unattended-upgrades and server reboot notifications
unattended_upgrades_mail_to = "admin@app.example"

# Email address for Let's Encrypt ACME certificate notifications
acme_mail = "acme@app.example"

smtp_host = "smtp.app.example"
smtp_port = 587
smtp_from = "no-reply@app.example"

# =============================================================================
# Application-Specific Environment Variables (optional)
# =============================================================================

# The module only sets infrastructure vars (APP_DOMAIN, ACME_MAIL,
# ACME_STORAGE_DIR, TRAEFIK_DASHBOARD_USERS). Define all application-specific
# env vars here — they are merged into the .env file deployed to the server.
#
# app_env_vars = {
#   NODE_ENV    = "production"
#   DB_HOST     = "database"
#   DB_PORT     = "5432"
#   DB_NAME     = "myapp"
#   DB_USER     = "myapp"
#   DB_VOLUME   = "/mnt/storage/var/docker/postgresql"
#   SOME_API_KEY = "secret-value"
# }
#
# For generated secrets (passwords, tokens), create random_password resources
# in your environment's main.tf and merge them — see README.md for an example.
